{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BrandonDucar/toolgym/main/schemas/agent-tool-mastery-credential-v0.1.schema.json",
  "title": "ToolGym Agent Tool Mastery Credential v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "type", "issuer", "validFrom", "validUntil", "credentialSubject", "evidence"],
  "properties": {
    "schema": { "const": "https://raw.githubusercontent.com/BrandonDucar/toolgym/main/schemas/agent-tool-mastery-credential-v0.1.schema.json" },
    "id": { "type": "string", "format": "uri" },
    "type": { "type": "array", "prefixItems": [{ "const": "AgentToolMasteryCredential" }], "minItems": 1 },
    "issuer": {
      "type": "object",
      "required": ["id", "name"],
      "properties": { "id": { "type": "string", "format": "uri" }, "name": { "type": "string" } }
    },
    "validFrom": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "credentialSubject": {
      "type": "object",
      "required": ["id", "name", "adapter", "achievement"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adapter": { "type": "string" },
        "achievement": {
          "type": "object",
          "required": ["name", "level", "criteriaVersion"],
          "properties": {
            "name": { "type": "string" },
            "level": { "const": "proctored-field-mastery" },
            "criteriaVersion": { "type": "string" }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["workoutReceipts", "fieldExam"],
      "properties": {
        "workoutReceipts": { "type": "array", "minItems": 4, "items": { "type": "object" } },
        "fieldExam": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "taskSummary", "evidenceUrl", "environment", "reviewer", "reviewedAt", "reviewMethod", "independentlyAttested"],
          "properties": {
            "id": { "type": "string" },
            "taskSummary": { "type": "string" },
            "evidenceUrl": { "type": "string", "format": "uri" },
            "environment": { "type": "string" },
            "reviewer": { "type": "string" },
            "reviewedAt": { "type": "string", "format": "date-time" },
            "reviewMethod": { "const": "independent-human-attestation" },
            "independentlyAttested": { "const": true }
          }
        }
      }
    }
  }
}
